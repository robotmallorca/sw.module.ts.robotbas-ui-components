        <div data-slot="item" class="dropdown-item" data-reka-collection-item="" role="option" aria-labelledby="reka-select-item-text-v-0-0-3" aria-selected="false" data-state="unchecked" tabindex="-1"><i class="i-lucide-circle-plus" data-slot="itemLeadingIcon"></i><span data-slot="itemWrapper" class=""><span id="reka-select-item-text-v-0-0-3" data-slot="itemLabel" class="">Todo</span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--></span>
        </div>
        <div data-slot="item" class="dropdown-item" data-reka-collection-item="" role="option" aria-labelledby="reka-select-item-text-v-0-0-4" aria-selected="false" data-state="unchecked" tabindex="-1"><i class="i-lucide-circle-arrow-up" data-slot="itemLeadingIcon"></i><span data-slot="itemWrapper" class=""><span id="reka-select-item-text-v-0-0-4" data-slot="itemLabel" class="">In Progress</span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--></span>
        </div>
        <div data-slot="item" class="dropdown-item" data-reka-collection-item="" role="option" aria-labelledby="reka-select-item-text-v-0-0-5" aria-selected="false" data-state="unchecked" tabindex="-1"><i class="i-lucide-circle-check" data-slot="itemLeadingIcon"></i><span data-slot="itemWrapper" class=""><span id="reka-select-item-text-v-0-0-5" data-slot="itemLabel" class="">Done</span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--></span>
        </div>
        <div data-slot="item" class="dropdown-item" data-reka-collection-item="" role="option" aria-labelledby="reka-select-item-text-v-0-0-6" aria-selected="false" data-state="unchecked" tabindex="-1"><i class="i-lucide-circle-x" data-slot="itemLeadingIcon"></i><span data-slot="itemWrapper" class=""><span id="reka-select-item-text-v-0-0-6" data-slot="itemLabel" class="">Canceled</span>
          <!--v-if--></span><span data-slot="itemTrailing" class=""><!--v-if--></span>
        </div>
      </div>
    </div>
    <!--v-if-->
  </div>
</div>


<!--teleport end-->
<!--v-if-->"
`;
