exports[`AvatarGroup > renders with as correctly 1`] = `"<span data-slot="root" class="avatar-group" aria-hidden="true"><!--v-if--><span aria-hidden="true" data-slot="root" class="avatar avatar-group-base"><img src="https://github.com/noook.png" alt="Neil Richter" width="32" height="32" data-slot="image" class="avatar-image"></span><span aria-hidden="true" data-slot="root" class="avatar avatar-group-base"><img src="https://github.com/romhml.png" alt="Romain Hamel" width="32" height="32" data-slot="image" class="avatar-image"></span><span aria-hidden="true" data-slot="root" class="avatar avatar-group-base"><img src="https://github.com/benjamincanac.png" alt="Benjamin Canac" width="32" height="32" data-slot="image" class="avatar-image"></span></span>"`;

