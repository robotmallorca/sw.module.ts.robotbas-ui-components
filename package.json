{
  "name": "@robotbas/ui",
  "version": "0.0.1",
  "description": "RobotBAS Vue UI components (Robotbas*) shared across webapps. Packaged as a Nuxt module.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robotmallorca/sw.module.ts.robotbas-ui-components.git"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/module.ts",
      "import": "./src/module.ts"
    },
    "./types": {
      "types": "./src/runtime/types/index.ts",
      "import": "./src/runtime/types/index.ts"
    },
    "./types/*": {
      "types": "./src/runtime/types/*.ts",
      "import": "./src/runtime/types/*.ts"
    },
    "./composables/*": {
      "types": "./src/runtime/composables/*.ts",
      "import": "./src/runtime/composables/*.ts"
    },
    "./components/*": {
      "types": "./src/runtime/components/*",
      "import": "./src/runtime/components/*"
    },
    "./package.json": "./package.json"
  },
  "main": "./src/module.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxi prepare playground",
    "generate": "nuxi generate playground",
    "preview": "nuxi preview playground",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "nuxi typecheck playground"
  },
  "dependencies": {
    "@nuxt/kit": "^3.16.0",
    "@standard-schema/spec": "^1.0.0",
    "@vueuse/core": "^13.0.0",
    "defu": "^6.1.4",
    "ohash": "^2.0.0",
    "superstruct": "^2.0.2"
  },
  "peerDependencies": {
    "reka-ui": ">=1.0.0",
    "vue": "^3.4.0",
    "vue-i18n": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "vue-i18n": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.3.0",
    "@nuxt/schema": "^3.16.0",
    "@nuxt/test-utils": "^3.17.0",
    "@types/node": "latest",
    "@vue/test-utils": "^2.4.11",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "eslint": "^9.23.0",
    "happy-dom": "^20.10.6",
    "nuxt": "^3.16.0",
    "reka-ui": "^2.0.0",
    "sass": "^1.80.0",
    "typescript": "~5.8.0",
    "vitest": "^3.1.0",
    "vitest-axe": "^0.1.0",
    "vue-i18n": "^11.0.0",
    "vue-tsc": "^2.2.0"
  }
}
